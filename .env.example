# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
TARGET_REPO=owner/repo               # the only project this server drives, e.g. jack/musicbox
GITHUB_TOKEN=ghp_...                 # contents:write, pull_requests:write
WORKSPACE_DIR=/data/workspaces
DATA_DIR=/data/db
CF_ACCESS_TEAM_DOMAIN=yourteam       # https://<team>.cloudflareaccess.com
CF_ACCESS_AUD=                       # application audience tag

# --- Optional ---
DEV_AGENT_TRUST_LOCAL=0              # 1 = skip CF Access verification (local dev only)
WORKSPACE_TTL_DAYS=14
PORT=3000                            # internal port the server binds inside the container;
                                     # the host-side published port is set in
                                     # systemd/dev-agent-server.container (PublishPort=...)
ANTHROPIC_MODEL=claude-sonnet-4-5
SANDBOX_NETWORK=dev-agent-server_agent_egress  # must match `<compose-project>_<network>`
PROXY_URL=http://proxy:8888

# Container engine socket on the host. Mounted into the server container at
# /var/run/docker.sock. Use the podman socket on Fedora.
#   Docker:           /var/run/docker.sock
#   Podman (rootful): /run/podman/podman.sock
#   Podman (rootless): /run/user/1000/podman/podman.sock
CONTAINER_SOCKET=/run/user/1000/podman/podman.sock

# Per-session sandbox container UID handling.
# Rootless podman: set SANDBOX_USERNS=keep-id so the sandbox's UID matches
# yours on disk. Leave SANDBOX_USER as 1000:1000 (matches the `agent` user in
# sandbox/Dockerfile.base) or empty to use the image default.
# Docker / rootful podman: leave SANDBOX_USERNS empty.
SANDBOX_USERNS=keep-id
SANDBOX_USER=1000:1000

# Container engine CLI used inside the server to drive per-session sandboxes.
#   docker (default): works against Docker Engine and against podman's
#                     docker-compatible socket for most things, BUT rejects
#                     --userns=keep-id client-side.
#   podman:           required if SANDBOX_USERNS=keep-id. The image ships
#                     podman-remote, which talks to the same socket via
#                     CONTAINER_HOST=unix:///var/run/docker.sock.
ENGINE_CLI=podman

# Max age (days) for built dev-agent-sandbox:* images. The server prunes
# anything older on boot and once per day. Skips images in use.
SANDBOX_IMAGE_MAX_AGE_DAYS=14

# Seccomp profile for per-session sandbox containers.
#   SECCOMP_PROFILE       in-container path the server checks for existence
#                         (skip seccomp if not present).
#   SECCOMP_PROFILE_HOST  path passed to docker/podman --security-opt; resolved
#                         on the HOST by the engine daemon. Only set this if
#                         the server itself runs in a container.
# When the server runs directly on the host, leave SECCOMP_PROFILE_HOST empty.
SECCOMP_PROFILE=/app/sandbox/seccomp.json
SECCOMP_PROFILE_HOST=

# Workspace path translation. The server creates per-session worktrees under
# WORKSPACE_DIR (in-container path), then asks the engine to bind-mount each
# worktree into the sandbox container. The engine resolves bind-mount sources
# on the HOST, so we must translate the in-container path to the host path.
#   docker named volume: /var/lib/docker/volumes/<project>_workspaces/_data
#   podman rootless:     $HOME/.local/share/containers/storage/volumes/<name>/_data
#   bind mount:          same as WORKSPACE_DIR (set them equal, no translation)
# Leave empty if the server runs directly on the host.
WORKSPACE_DIR_HOST=
