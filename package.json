{
  "name": "dev-agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic Claude-driven dev agent server. Drives any repo that ships a .dev-agent/ directory.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p . --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.10",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
